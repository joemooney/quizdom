
# AIDA distributed store (orphan branch worktree)
# Bare-name pattern catches session-worktree symlinks back to the
# canonical store. trace:EPIC-21 | ai:claude
.aida-store/
.aida-store

# AIDA runtime state — deny-by-default. Anything under .aida/ is
# per-clone runtime state (cache, sessions, roles, env shims, review
# prompts, server data, etc.) unless explicitly allow-listed below.
# Adding a new runtime file under .aida/ requires no gitignore change;
# tracking a new project-config file requires an explicit `!` line.
# trace:BUG-73 | ai:claude
.aida/*

# Tracked exceptions: project-level config that lives in the repo.
!.aida/config.toml

# Per-project skill extensions are tracked project assets, not
# runtime state — they live under .claude/ which is tracked by
# default. Do not add ignore rules for .claude/skills/local/ or
# any <skill>.local.md file; the whole team should pick them up on
# `git pull`. See docs/extending-skills.md. trace:STORY-305 | ai:claude

# Personal Claude Code notes — per-machine, never team-shared.
# CLAUDE.local.md loads alongside CLAUDE.md at session start but
# stays out of git so reviewer-feedback dumps + personal-habit
# reminders stay private. See the scaffolded file's own header
# for usage guidance.
CLAUDE.local.md

# Rust build output and local quizdom session logs.
/target/
/data/
